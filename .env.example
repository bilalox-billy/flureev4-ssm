# ═══════════════════════════════════════════════════════════════════
#  Fluree v4 Python Tutorial — Environment Variables
#  ─────────────────────────────────────────────────
#  Copy this file to .env and fill in your values:
#      cp .env.example .env   (Linux/macOS)
#      copy .env.example .env (Windows)
#
#  NEVER commit .env to version control — it contains secrets.
#  The .gitignore already excludes it.
# ═══════════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────────
#  REQUIRED FOR BOTH MODES
# ───────────────────────────────────────────────────────────────────

# The root URL of your Fluree server hosted on AWS.
# No trailing slash. No /v1/fluree suffix — the client adds that.
#
# Examples:
#   http://localhost:8090                            (local dev)
#   https://my-fluree-alb.us-east-1.elb.amazonaws.com   (AWS ALB)
#   https://fluree.my-company.com                    (custom domain)
FLUREE_BASE_URL=https://your-fluree-server.example.com

# The ledger (database) name to query and write to.
# Format: "namespace/name"
#
# Examples:
#   my-org/production
#   demo/test-ledger
FLUREE_LEDGER=my-org/my-ledger


# ───────────────────────────────────────────────────────────────────
#  MODE A — OIDC (browser-based login)
#  Fill these in if you're using Mode A.
#  If your server exposes /.well-known/fluree.json correctly,
#  the tutorial can discover these automatically — but having them
#  here as overrides is safer and faster.
# ───────────────────────────────────────────────────────────────────

# Your OIDC Identity Provider issuer URL.
#
# AWS Cognito example:
#   https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXXXX
#
# Okta example:
#   https://dev-12345678.okta.com/oauth2/default
#
# Auth0 example:
#   https://your-tenant.us.auth0.com
OIDC_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXXXX

# The OAuth 2.0 Client ID registered for the Fluree CLI / this app.
# This is a public identifier — not a secret.
OIDC_CLIENT_ID=fluree-cli

# The Fluree token exchange endpoint.
# After OIDC login, the CLI sends your IdP token here to get a
# Fluree-scoped Bearer token in return.
# Usually: {FLUREE_BASE_URL}/v1/fluree/auth/exchange
FLUREE_EXCHANGE_URL=https://your-fluree-server.example.com/v1/fluree/auth/exchange

# OAuth scopes to request (space-separated).
# "openid" is required. "profile" and "email" are common additions.
OIDC_SCOPES=openid profile

# Local port for the PKCE browser callback listener.
# Must be allowlisted in your IdP's callback URLs.
# Fluree default: 8400 (also tries 8401-8405 as fallback).
# For AWS Cognito: add http://127.0.0.1:8400/callback to the app client settings.
OIDC_REDIRECT_PORT=8400


# ───────────────────────────────────────────────────────────────────
#  MODE B — Manual Bearer Token
#  Fill this in if you're using Mode B (or leave it empty to be
#  prompted at runtime).
# ───────────────────────────────────────────────────────────────────

# A pre-issued Fluree Bearer token (JWT).
# Where to get one:
#   - Ask your Fluree/AWS administrator
#   - Run: fluree auth login --remote <name>
#         then copy token from .fluree/config.toml
#   - Run Mode A (OIDC) and copy the access_token from the output
#
# Example (truncated):
#   FLUREE_BEARER_TOKEN=eyJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1NiIsImtpZCI6Ii...
FLUREE_BEARER_TOKEN=
